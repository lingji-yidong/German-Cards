// Shared signing defaults. Keep secrets and personal team IDs out of this file.
// Copy Signing.example.xcconfig to Signing.local.xcconfig for local device builds.

CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM =
PRODUCT_BUNDLE_IDENTIFIER = uk.habseligkeiten.GermanCards

#include? "Signing.local.xcconfig"

// Cross-platform build support. Personal signing still belongs in Signing.local.xcconfig.
SUPPORTED_PLATFORMS = iphoneos iphonesimulator macosx
SUPPORTS_MACCATALYST = YES
DERIVE_MACCATALYST_PRODUCT_BUNDLE_IDENTIFIER = NO
